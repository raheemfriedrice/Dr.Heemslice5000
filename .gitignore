# Transcript raw dumps (large — track by uuid reference in CSV only)
XOCLAUDIXO/TRANSCRIPTION/*.txt
XOCLAUDIXO/TRANSCRIPTION/*.json
XOCLAUDIXO/TRANSCRIPTION/*.srt
XOCLAUDIXO/TRANSCRIPTION/*.vtt

# Temp intake staging
XOCLAUDIXO/INTAKE/*.tmp
